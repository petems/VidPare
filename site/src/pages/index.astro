---
import { Picture } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../content/site.config';
import { faqs, featureItems } from '../content/features';
import demoPoster from '../assets/demo-poster.jpg';

const heroTitleLines = siteConfig.heroTitle.split('\n').filter((line) => line.trim().length > 0);
---

<MainLayout>
  <main id="top">
    <header class="site-header">
      <nav>
        <a href="#features">Features</a>
        <a href="#tech">Tech</a>
        <a href="#faq">FAQ</a>
      </nav>
    </header>

    <section id="hero" class="hero surface reveal">
      <h1 class="hero-brand"><a href="#top">{siteConfig.appName}</a></h1>
      <p class="eyebrow">Native macOS video trimmer</p>
      <h2 class="hero-title-stack">
        {
          heroTitleLines.map((line) => (
            <span class="line">{line}</span>
          ))
        }
      </h2>
      <p class="lede">{siteConfig.heroSubtitle}</p>
      <div class="cta-row">
        <a class="btn primary" href={siteConfig.cta.downloadUrl} target="_blank" rel="noreferrer">{siteConfig.cta.primaryLabel}</a>
        <a class="btn secondary" href={siteConfig.cta.sourceUrl} target="_blank" rel="noreferrer">{siteConfig.cta.secondaryLabel}</a>
      </div>
      <p class="microcopy">Does one thing well: trim videos easily, quickly, and natively.</p>
      <div class="hero-demo" data-demo-player data-video-src="/demo.mp4" data-poster-src={demoPoster.src}>
        <button class="hero-demo__trigger" type="button" data-demo-trigger>
          <Picture
            class="hero-demo__poster"
            src={demoPoster}
            alt=""
            widths={[640, 920, 1280]}
            sizes="(max-width: 960px) 100vw, 920px"
            formats={['avif', 'webp']}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <span class="hero-demo__overlay">
            <span class="hero-demo__play">Play demo video</span>
            <span class="hero-demo__hint">Loads the full MP4 only after you press play.</span>
          </span>
        </button>
        <noscript>
          <img
            class="hero-demo__poster"
            src={demoPoster.src}
            alt="VidPare trimming a video clip in its native macOS interface."
            width="1280"
            height="800"
            loading="eager"
            decoding="async"
          />
        </noscript>
      </div>
    </section>

    <section class="trust-strip centered-section" aria-label="Key guarantees">
      {
        siteConfig.trustItems.map((item) => (
          <span class="pill">{item}</span>
        ))
      }
    </section>

    <section id="features" class="feature-grid reveal centered-section">
      {
        featureItems.map((feature) => (
          <article class="card">
            <p class="badge">{feature.badge}</p>
            <h2>{feature.title}</h2>
            <p>{feature.body}</p>
          </article>
        ))
      }
    </section>

    <section id="tech" class="tech-block surface reveal centered-section">
      <h2>Not a shell over ffmpeg</h2>
      <p>
        VidPare is built directly on Apple frameworks: Swift, SwiftUI, AVFoundation, and VideoToolbox.
        That gives you real macOS integration, hardware-accelerated media pipelines, and predictable behavior
        without external binary glue.
      </p>
      <div class="code-chip">
        <span>SwiftUI Shell</span>
        <span>VideoEngine (AVFoundation)</span>
        <span>No ffmpeg dependency</span>
      </div>
    </section>

    <section class="workflow reveal centered-section">
      <h2>How it works</h2>
      <ol>
        <li>
          <strong>Open your clip</strong>
          <p>Drop in MP4, MOV, or M4V directly from Finder.</p>
        </li>
        <li>
          <strong>Set trim points</strong>
          <p>Use timeline handles to choose exactly what you want to keep.</p>
        </li>
        <li>
          <strong>Export fast</strong>
          <p>Use passthrough where possible for near-instant outputs.</p>
        </li>
      </ol>
    </section>

    <section class="cta-banner reveal centered-section" aria-label="download">
      <h2>Free, open source, and built for macOS creators</h2>
      <p>Use VidPare when you want trimming done in seconds, not a heavyweight editing suite.</p>
      <div class="cta-row">
        <a class="btn primary" href={siteConfig.cta.downloadUrl} target="_blank" rel="noreferrer">{siteConfig.cta.primaryLabel ?? "Download Latest Release"}</a>
        <a class="btn secondary" href={siteConfig.cta.sourceUrl} target="_blank" rel="noreferrer">{siteConfig.cta.secondaryLabel ?? "Star on GitHub"}</a>
      </div>
    </section>

    <section id="faq" class="faq reveal centered-section">
      <h2>FAQ</h2>
      {
        faqs.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))
      }
    </section>
  </main>

  <script src="../scripts/main.ts"></script>
</MainLayout>
